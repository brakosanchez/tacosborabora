# =====================================
# Configuración de la Aplicación
# =====================================

# Entorno de ejecución (development, production, staging)
ENVIRONMENT=development

# Configuración del servidor
DOMAIN=localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# Configuración de la base de datos MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=tacosborabora

# Configuración de seguridad
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 días

# Configuración de CORS (orígenes permitidos separados por comas)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Configuración de CSRF
CSRF_COOKIE_NAME=csrftoken
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_COOKIE_HTTP_ONLY=True
CSRF_COOKIE_SECURE=False  # Cambiar a True en producción con HTTPS
CSRF_COOKIE_SAMESITE=lax  # lax, strict, o none
CSRF_COOKIE_DOMAIN=
CSRF_COOKIE_PATH=/
CSRF_COOKIE_MAX_AGE=86400  # 24 horas
CSRF_SECRET_KEY=your-csrf-secret-key-here

# Configuración de rate limiting
RATE_LIMIT_DEFAULT=1000/day, 100/hour
RATE_LIMIT_AUTHENTICATED=5000/day, 500/hour

# Configuración de contraseñas
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_NUMBERS=True
PASSWORD_REQUIRE_SPECIAL_CHARS=True

# Configuración de sesión
SESSION_COOKIE_SECURE=False  # Cambiar a True en producción con HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=lax
SESSION_LIFETIME=86400  # 24 horas

# Configuración de encabezados de seguridad
SECURE_HSTS_SECONDS=31536000  # 1 año
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_REFERRER_POLICY=same-origin

# Usuario administrador inicial
FIRST_SUPERUSER=admin@tacosborabora.com
FIRST_SUPERUSER_PASSWORD=changeme

# Configuración de correo electrónico (opcional, para recuperación de contraseña, etc.)
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=user@example.com
# SMTP_PASSWORD=your-email-password
# EMAIL_FROM=noreply@tacosborabora.com
# EMAIL_FROM_NAME="Tacos Bora Bora"

# Configuración de Cloudflare (opcional, si usas Cloudflare)
# CLOUDFLARE_API_TOKEN=your-cloudflare-token
# CLOUDFLARE_ZONE_ID=your-zone-id

# Configuración de Google reCAPTCHA (opcional, para protección de formularios)
# RECAPTCHA_SITE_KEY=your-recaptcha-site-key
# RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Configuración de Google Analytics (opcional)
# GOOGLE_ANALYTICS_ID=your-ga-id

# Configuración de Mapbox (opcional, para mapas)
# MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# Configuración de pasarelas de pago (opcional)
# STRIPE_SECRET_KEY=your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Configuración de redes sociales (opcional, para compartir)
# FACEBOOK_APP_ID=your-facebook-app-id
# TWITTER_HANDLE=@tacosborabora
# INSTAGRAM_USERNAME=tacosborabora

# Configuración de AWS (opcional, para almacenamiento de archivos)
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# Configuración de Redis (opcional, para caché y colas)
# REDIS_URL=redis://localhost:6379/0

# Configuración de Celery (opcional, para tareas en segundo plano)
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Configuración de Sentry (opcional, para monitoreo de errores)
# SENTRY_DSN=your-sentry-dsn

# Configuración de Logging (opcional)
# LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# LOG_FILE=logs/app.log

# Configuración de Pruebas (opcional)
# TEST_DATABASE_URL=sqlite:///./test.db
# TESTING=False
